{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Equivalence report (machine-readable companion)",
  "description": "JSON companion ao equivalence-report.md de stage 06. Permite tooling automatizado.",
  "type": "object",
  "required": ["target_path", "level_attempted", "level_achieved", "results"],
  "properties": {
    "target_path": { "type": "string" },
    "source_path": { "type": "string" },
    "ran_at": { "type": "string", "format": "date-time" },
    "level_attempted": {
      "type": "string",
      "enum": ["L1", "L2", "L3", "L4"]
    },
    "level_achieved": {
      "type": "string",
      "enum": ["L0", "L1", "L2", "L3", "L4"],
      "description": "L0 = não compila."
    },
    "results": {
      "type": "object",
      "properties": {
        "L1": { "$ref": "#/definitions/level_result" },
        "L2": { "$ref": "#/definitions/level_result" },
        "L3": { "$ref": "#/definitions/level_result" },
        "L4": { "$ref": "#/definitions/level_result" }
      }
    },
    "signed_off": { "type": "boolean" },
    "gaps": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "definitions": {
    "level_result": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pass", "fail", "skipped"]
        },
        "evidence_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "metrics": {
          "type": "object",
          "additionalProperties": true
        },
        "notes": { "type": "string" }
      }
    }
  }
}
